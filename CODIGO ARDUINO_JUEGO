#include <WiFi.h>
#include <HTTPClient.h>
#include <ArduinoJson.h>
#include <WebServer.h>

// ============ CONFIGURACIÓN ============
const char* ssid     = "IZZI-0793";       
const char* password = "s9ysjd3x";   

const char* insertUrl = "http://192.168.1.9:3000/api/snake"; 
// ============ SERVIDOR WEB EN ESP32 ============
WebServer server(80);

// ============ LED ============
#define LED_PIN 48

void setLEDColor(String color) {
  if (color == "off")    rgbLedWrite(LED_PIN, 0, 0, 0);
  else if (color == "red")   rgbLedWrite(LED_PIN, 50, 0, 0);
  else if (color == "green") rgbLedWrite(LED_PIN, 0, 50, 0);
  else if (color == "blue")  rgbLedWrite(LED_PIN, 0, 0, 50);
  else if (color == "yellow") rgbLedWrite(LED_PIN, 50, 30, 0);
}

// ============ Recibir puntaje del navegador ============
void handleScore() {

  server.sendHeader("Access-Control-Allow-Origin", "*");
  server.sendHeader("Access-Control-Allow-Methods", "POST, OPTIONS");
  server.sendHeader("Access-Control-Allow-Headers", "Content-Type");

  if (server.method() == HTTP_OPTIONS) {
    server.send(200);
    return;
  }

  if (!server.hasArg("plain")) {
    server.send(400, "application/json", "{\"error\":\"No body\"}");
    return;
  }

  String body = server.arg("plain");
  Serial.println("\n📥 Puntaje recibido del navegador:");
  Serial.println(body);

  // Parsear JSON
  DynamicJsonDocument doc(256);
  DeserializationError error = deserializeJson(doc, body);

  if (error) {
    Serial.println("✗ Error parseando JSON");
    server.send(400, "application/json", "{\"error\":\"JSON invalido\"}");
    return;
  }

  const char* nombre  = doc["nombre"];
  int puntaje         = doc["puntaje"];

  Serial.print("Jugador: "); Serial.println(nombre);
  Serial.print("Puntaje: "); Serial.println(puntaje);

  // Parpadeo amarillo mientras se envía a la BD
  setLEDColor("yellow");

  // Reenviar a Node.js API
  bool ok = sendToAPI(nombre, puntaje);

  if (ok) {
    setLEDColor("green");
    server.send(200, "application/json", "{\"success\":true,\"message\":\"Guardado en BD\"}");
  } else {
    setLEDColor("red");
    server.send(500, "application/json", "{\"success\":false,\"message\":\"Error al guardar\"}");
  }
}

// ============ ENVIAR A NODE API ============
bool sendToAPI(const char* nombre, int puntaje) {
  Serial.println("\nEnviando a Node.js API...");

  HTTPClient http;
  http.begin(insertUrl);
  http.addHeader("Content-Type", "application/json");

  DynamicJsonDocument doc(256);
  doc["nombre"]  = nombre;
  doc["puntaje"] = puntaje;

  String jsonString;
  serializeJson(doc, jsonString);

  Serial.print("Payload: "); Serial.println(jsonString);

  int httpCode = http.POST(jsonString);

  if (httpCode == 200) {
    Serial.println("✓ Guardado en MSSQL exitosamente");
    Serial.println(http.getString());
    http.end();
    return true;
  } else {
    Serial.print("✗ Error HTTP: "); Serial.println(httpCode);
    Serial.println(http.getString());
    http.end();
    return false;
  }
}

// ============ SETUP ============
void setup() {
  Serial.begin(115200);
  delay(1000);

  Serial.println("\n=== ESP32 SNAKE SCORE SERVER ===");

  digitalWrite(LED_PIN, LOW);

  // Conectar WiFi
  Serial.print("Conectando a WiFi: "); Serial.println(ssid);
  WiFi.mode(WIFI_STA);
  WiFi.begin(ssid, password);
  setLEDColor("blue");

  int attempts = 0;
  while (WiFi.status() != WL_CONNECTED && attempts < 30) {
    delay(500);
    Serial.print(".");
    attempts++;
  }

  if (WiFi.status() == WL_CONNECTED) {
    Serial.println("\n✓ WiFi conectado!");
    Serial.print("IP de la ESP32: ");
    Serial.println(WiFi.localIP());
    setLEDColor("green");
  } else {
    Serial.println("\n✗ No se pudo conectar al WiFi");
    setLEDColor("red");
    delay(5000);
    ESP.restart();
  }

  // Configurar rutas del servidor
  server.on("/score", handleScore);
  server.on("/score", HTTP_OPTIONS, handleScore); // CORS preflight
  server.on("/ping", []() {
    server.sendHeader("Access-Control-Allow-Origin", "*");
    server.send(200, "application/json", "{\"status\":\"ok\"}");
  });

  server.begin();
  Serial.println("✓ Servidor HTTP corriendo en puerto 80");
  Serial.println("Esperando puntajes del juego...");
}

// ============ LOOP ============
void loop() {
  server.handleClient();
}
